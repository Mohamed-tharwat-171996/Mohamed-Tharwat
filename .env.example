# REQUIRED: Generate a random 32+ character string. Never use the default!
JWT_SECRET=

# Firebase Config (JSON string). Use DEV_FIREBASE_CONFIG and PROD_FIREBASE_CONFIG for separate projects.
FIREBASE_CONFIG=

# Application Environment: production | development
# IMPORTANT: You MUST set this manually in AI Studio Secrets for each deployment!
# For the live/public deployment (Shared App): APP_ENV=production
# For the test/preview deployment (Development App): APP_ENV=development
# Do NOT leave empty - this ensures complete SQLite and Firestore isolation between environments!
APP_ENV=
